IMAGE_TAG=latest

NODE_ENV=production
PORT=3000

DATABASE_URL=postgres://user:password@db.example.com:5432/booker

JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=7d

DEFAULT_TENANT_HOST=

# Опционально: первый super_admin при пустой БД
# PLATFORM_BOOTSTRAP_EMAIL=
# PLATFORM_BOOTSTRAP_PASSWORD=

REDIS_URL=redis://redis:6379

# MongoDB — настройки брендинга тенантов (темы)
MONGODB_URI=mongodb://mongo:27017/booker

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Workspace Booker <noreply@example.com>"
# Имя в шапке писем (worker)
MAIL_APP_NAME=Бронирование рабочих мест

# Полный URL страницы входа платформенной админки (кнопка в письме новому super_admin; worker)
# PLATFORM_ADMIN_LOGIN_URL=https://platform.example.com/

API_UPSTREAM=api:3000
PLATFORM_HOST=platform.example.com

# Публичный лендинг (React): отдельный virtual host в nginx Docker-образа `web`.
# Нельзя использовать как домен организации (см. API: зарезервировано).
LANDING_HOST=landing.example.com
# Опционально: полный URL — hostname будет зарезервирован как и у PLATFORM_URL
# LANDING_URL=https://landing.example.com/

HTTP_PORT=80

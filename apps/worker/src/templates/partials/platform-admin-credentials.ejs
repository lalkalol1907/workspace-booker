              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#ffffff;border-left:1px solid #e2e8f0;border-right:1px solid #e2e8f0;">
                <tr>
                  <td style="padding:24px 32px 12px;">
                    <p style="margin:0;font-size:15px;line-height:1.65;color:#334155;"><%= intro %></p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:8px 32px 28px;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-radius:10px;background:#f8fafc;border:1px solid #e2e8f0;">
                      <tr>
                        <td style="padding:18px 20px;">
                          <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                            <tr>
                              <td style="padding:6px 0;font-size:13px;color:#64748b;">Имя</td>
                            </tr>
                            <tr>
                              <td style="padding:0 0 14px;font-size:15px;font-weight:600;color:#0f172a;"><%= displayName %></td>
                            </tr>
                            <tr>
                              <td style="padding:6px 0;font-size:13px;color:#64748b;">Email (логин)</td>
                            </tr>
                            <tr>
                              <td style="padding:0 0 14px;font-size:15px;font-weight:600;color:#0f172a;"><%= email %></td>
                            </tr>
                            <tr>
                              <td style="padding:6px 0;font-size:13px;color:#64748b;">Временный пароль</td>
                            </tr>
                            <tr>
                              <td style="padding:0 0 14px;font-size:15px;font-weight:600;font-family:ui-monospace,monospace;color:#0f172a;word-break:break-all;"><%= temporaryPassword %></td>
                            </tr>
                            <% if (typeof loginUrl !== 'undefined' && loginUrl) { %>
                            <tr>
                              <td style="padding:12px 0 0;">
                                <a href="<%= loginUrl %>" style="display:inline-block;background:#4f46e5;color:#ffffff;text-decoration:none;font-size:14px;font-weight:600;padding:10px 18px;border-radius:8px;">Открыть панель платформы</a>
                              </td>
                            </tr>
                            <% } %>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

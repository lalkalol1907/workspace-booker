<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title><%= pageTitle %></title>
  <style type="text/css">
    @media only screen and (max-width: 620px) {
      .c { width: 100% !important; }
      .px { padding-left: 16px !important; padding-right: 16px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f1f5f9;padding:24px 0;">
    <tr>
      <td align="center">
        <table role="presentation" class="c" width="600" cellspacing="0" cellpadding="0" style="max-width:600px;width:100%;">
          <tr>
            <td class="px" style="padding:0 24px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-radius:12px 12px 0 0;overflow:hidden;background:linear-gradient(135deg,#4f46e5 0%,#6366f1 45%,#7c3aed 100%);">
                <tr>
                  <td style="padding:28px 32px 24px;">
                    <p style="margin:0;font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.8);"><%= appName %></p>
                    <h1 style="margin:10px 0 0;font-size:22px;line-height:1.35;font-weight:700;color:#ffffff;"><%= headline %></h1>
                    <% if (typeof badgeLabel !== 'undefined' && badgeLabel) { %>
                    <table role="presentation" cellspacing="0" cellpadding="0" style="margin-top:14px;">
                      <tr>
                        <td style="background-color:<%= badgeBg %>;color:#ffffff;font-size:12px;font-weight:600;padding:6px 12px;border-radius:999px;"><%= badgeLabel %></td>
                      </tr>
                    </table>
                    <% } %>
                  </td>
                </tr>
              </table>

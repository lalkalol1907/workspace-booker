DATABASE_URL=postgres://postgres:postgres@localhost:5432/booker
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=3000

# Tenant hostname when the request Host cannot be resolved (optional).
# Must match an existing organizations.host value (e.g. localhost for dev).
DEFAULT_TENANT_HOST=localhost

MONGODB_URI=mongodb://localhost:27017/booker

# Зарезервированы для платформы/лендинга (нельзя присвоить организации).
# См. корневой .env — обычно задаются там же, что и для Docker.
# LANDING_HOST=landing.example.com
# LANDING_URL=https://landing.example.com/
